# ─────────────────────────────────────────
# 🔐 2FA + Address Bot — Environment Config
# by RayzellStores | t.me/RayzellStores
# ─────────────────────────────────────────

# Token bot dari @BotFather
BOT_TOKEN=your_bot_token_here

# Telegram User ID kamu (owner)
OWNER_ID=your_telegram_id_here

# Username bot (tanpa @)
BOT_USERNAME=your_bot_username

# Channel yang wajib di-join user
CHANNEL=@RayzellStores

# ── WEBHOOK (opsional, tapi DIREKOMENDASIKAN untuk respon cepat) ──
# Isi WEBHOOK_URL dengan URL publik kamu (dari Cloudflare Tunnel / domain)
# Kosongkan untuk pakai polling biasa
WEBHOOK_URL=
WEBHOOK_PORT=8443

# ─────────────────────────────────────────
# ⚡ PERFORMA — Redis + Local Bot API
# ─────────────────────────────────────────

# REDIS — cache session/state (kosongkan kalau Redis belum di-install)
# Default Redis lokal di VPS:
REDIS_URL=redis://127.0.0.1:6379

# LOCAL BOT API — eliminasi latency ke api.telegram.org
# Kosongkan untuk pakai server resmi (https://api.telegram.org)
BOT_API_ROOT=http://localhost:8081

# Kredensial Telegram API (dipakai saat run docker telegram-bot-api,
# BUKAN dipakai langsung oleh bot.js — hanya untuk referensi)
# TELEGRAM_API_ID=32773999
# TELEGRAM_API_HASH=d2eb7260911dbce615a1fb27f36d4b12
